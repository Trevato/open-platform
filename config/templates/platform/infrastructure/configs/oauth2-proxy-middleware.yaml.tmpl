apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: oauth2-proxy-auth
  namespace: oauth2-proxy
spec:
  forwardAuth:
    address: http://oauth2-proxy.oauth2-proxy.svc:4180/oauth2/auth
    trustForwardHeader: true
    authResponseHeaders:
      - X-Auth-Request-User
      - X-Auth-Request-Email
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: auth-redirect-page
  namespace: oauth2-proxy
data:
  index.html: |
    <!DOCTYPE html>
    <html>
    <head>
      <meta charset="utf-8">
      <title>Redirecting...</title>
      <script>
        window.location.href = 'https://${SERVICE_PREFIX}oauth2.${DOMAIN}/oauth2/start?rd=' + encodeURIComponent(window.location.href);
      </script>
    </head>
    <body>
      <p>Redirecting to sign in... <a href="https://${SERVICE_PREFIX}oauth2.${DOMAIN}/oauth2/start">Click here</a> if not redirected.</p>
    </body>
    </html>
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: auth-redirect
  namespace: oauth2-proxy
spec:
  replicas: 1
  selector:
    matchLabels:
      app: auth-redirect
  template:
    metadata:
      labels:
        app: auth-redirect
    spec:
      containers:
        - name: nginx
          image: nginx:alpine
          ports:
            - containerPort: 80
          volumeMounts:
            - name: html
              mountPath: /usr/share/nginx/html
              readOnly: true
          resources:
            requests:
              cpu: 10m
              memory: 16Mi
            limits:
              cpu: 100m
              memory: 128Mi
      volumes:
        - name: html
          configMap:
            name: auth-redirect-page
---
apiVersion: v1
kind: Service
metadata:
  name: auth-redirect
  namespace: oauth2-proxy
spec:
  selector:
    app: auth-redirect
  ports:
    - port: 80
      targetPort: 80
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: oauth2-proxy-redirect
  namespace: oauth2-proxy
spec:
  errors:
    status:
      - "401"
    service:
      name: auth-redirect
      port: 80
    query: "/"
