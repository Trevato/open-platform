config:
  # Do NOT add sessionTTL — 0.40.x binary crashes with -session-ttl flag
  oidc:
    secret:
      create: false
    externalSecret:
      enabled: true
      name: "oidc"
    issuerURL: https://${SERVICE_PREFIX}forgejo.${DOMAIN}
    callbackURL: https://${SERVICE_PREFIX}headlamp.${DOMAIN}/oidc-callback
    scopes: "openid,profile,email,groups,offline_access"
ingress:
  enabled: true
  ingressClassName: traefik
  hosts:
    - host: ${SERVICE_PREFIX}headlamp.${DOMAIN}
      paths:
        - path: /
          type: ImplementationSpecific

env:
  - name: HEADLAMP_CONFIG_OIDC_SKIP_TLS_VERIFY
    value: "${TLS_SKIP_VERIFY}"
