publicURL: "https://${SERVICE_PREFIX}meet.${DOMAIN}"

enableAuth: true
enableGuests: ${JITSI_ALLOW_GUESTS}

extraCommonEnvs:
  AUTH_TYPE: jwt
  JWT_APP_ID: "jitsi"

web:
  ingress:
    enabled: true
    ingressClassName: traefik
    hosts:
      - host: ${SERVICE_PREFIX}meet.${DOMAIN}
        paths: ["/"]

  extraEnvs:
    TOKEN_AUTH_URL: "https://${SERVICE_PREFIX}meet-auth.${DOMAIN}/room/{room}"

  initContainers:
    - name: build-ca-bundle
      image: alpine:3.22
      command: [sh, -c]
      args:
        - cat /etc/ssl/certs/ca-certificates.crt /platform-ca/ca.crt > /custom-certs/ca-certificates.crt 2>/dev/null || cp /etc/ssl/certs/ca-certificates.crt /custom-certs/ca-certificates.crt
      volumeMounts:
        - name: platform-ca
          mountPath: /platform-ca
          readOnly: true
        - name: custom-certs
          mountPath: /custom-certs

  extraContainers:
    - name: jitsi-oidc
      image: ghcr.io/marcelcoding/jitsi-openid:latest
      imagePullPolicy: Always
      ports:
        - name: http
          containerPort: 3000
      env:
        - name: JITSI_SECRET
          valueFrom:
            secretKeyRef:
              name: jitsi-secrets
              key: JWT_APP_SECRET
        - name: JITSI_URL
          value: "https://${SERVICE_PREFIX}meet.${DOMAIN}"
        - name: JITSI_SUB
          value: "${SERVICE_PREFIX}meet.${DOMAIN}"
        - name: ISSUER_URL
          value: "https://${SERVICE_PREFIX}forgejo.${DOMAIN}"
        - name: BASE_URL
          value: "https://${SERVICE_PREFIX}meet-auth.${DOMAIN}"
        - name: CLIENT_ID
          valueFrom:
            secretKeyRef:
              name: jitsi-oidc
              key: client-id
        - name: CLIENT_SECRET
          valueFrom:
            secretKeyRef:
              name: jitsi-oidc
              key: client-secret
        - name: VERIFY_ACCESS_TOKEN_HASH
          value: "false"
        - name: SSL_CERT_FILE
          value: /custom-certs/ca-certificates.crt
      volumeMounts:
        - name: custom-certs
          mountPath: /custom-certs
          readOnly: true
      resources:
        requests:
          cpu: 25m
          memory: 32Mi
        limits:
          cpu: 200m
          memory: 128Mi

  extraVolumes:
    - name: platform-ca
      configMap:
        name: platform-ca
        optional: true
    - name: custom-certs
      emptyDir: {}

  resources:
    requests:
      memory: 256Mi
      cpu: 100m
    limits:
      memory: 512Mi

prosody:
  jwt:
    existingSecretName: jitsi-secrets
  # BEGIN multinode
  affinity:
    nodeAffinity:
      preferredDuringSchedulingIgnoredDuringExecution:
        - weight: 60
          preference:
            matchExpressions:
              - key: open-platform.sh/node-role
                operator: In
                values:
                  - infra
  # END multinode

  persistence:
    enabled: true
    size: 5Gi

jicofo:
  resources:
    requests:
      memory: 256Mi
      cpu: 100m
    limits:
      memory: 512Mi

jvb:
  replicaCount: 1

  publicIPs:
    - ${JITSI_JVB_ADVERTISE_IP}
  useNodeIP: false
  stunServers: "stun.l.google.com:19302"
  UDPPort: 10000

  service:
    enabled: true
    type: NodePort
    nodePort: 10000

  resources:
    requests:
      memory: 512Mi
      cpu: 500m
    limits:
      memory: 2Gi
      cpu: "2"
