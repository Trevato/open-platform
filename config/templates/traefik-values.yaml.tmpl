api:
  dashboard: true
  insecure: true
logs:
  access:
    enabled: true
# BEGIN host-network
deployment:
  kind: DaemonSet
updateStrategy:
  type: RollingUpdate
  rollingUpdate:
    maxUnavailable: 1
    maxSurge: 0
hostNetwork: true
securityContext:
  capabilities:
    drop:
      - ALL
    add:
      - NET_BIND_SERVICE
  runAsUser: 0
  runAsGroup: 0
  runAsNonRoot: false
# END host-network
# BEGIN loadbalancer
deployment:
  kind: Deployment
  replicas: 2
# END loadbalancer
ports:
  web:
    port: 80
  websecure:
    port: 443
providers:
  kubernetesCRD:
    allowExternalNameServices: true
    allowEmptyServices: true
  kubernetesIngress:
    allowExternalNameServices: true
    allowEmptyServices: true
# BEGIN host-network
service:
  type: ClusterIP
# END host-network
# BEGIN loadbalancer
service:
  type: LoadBalancer
  annotations:
    metallb.universe.tf/address-pool: shared-infra
  spec:
    loadBalancerIP: ${METALLB_TRAEFIK_IP}
    externalTrafficPolicy: Local
# END loadbalancer
