api:
  dashboard: true
  insecure: true
logs:
  access:
    enabled: true
deployment:
  kind: DaemonSet
updateStrategy:
  type: RollingUpdate
  rollingUpdate:
    maxUnavailable: 1
    maxSurge: 0
hostNetwork: true
ports:
  web:
    port: 80
  websecure:
    port: 443
providers:
  kubernetesCRD:
    allowExternalNameServices: true
    allowEmptyServices: true
  kubernetesIngress:
    allowExternalNameServices: true
    allowEmptyServices: true
service:
  type: ClusterIP
