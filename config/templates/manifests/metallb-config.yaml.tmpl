apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: shared-infra
  namespace: metallb-system
spec:
  addresses:
    - ${METALLB_ADDRESS_POOL}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: shared-infra-l2
  namespace: metallb-system
spec:
  ipAddressPools:
    - shared-infra
  interfaces:
    - ${METALLB_INTERFACE}
