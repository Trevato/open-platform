# Open Platform Configuration
# Only domain is required. Everything else has sensible defaults.
# Configure networking, TLS, services, and domains via the console after deploy.

domain: myplatform.example.com

# admin:
#   username: opadmin
#   email: admin@example.com

# Jitsi (video conferencing) and Zulip (team messaging) are enabled by default.
# Uncomment to disable:
# jitsi:
#   enabled: false
# zulip:
#   enabled: false

# pgAdmin 4 (database management) — disabled by default:
# pgadmin:
#   enabled: true

# Infrastructure mode: "bundled" (default) or "external"
#
# bundled: Open Platform installs and manages Traefik, MetalLB, cert-manager, and CNPG.
#          Best for fresh clusters where OP is the only tenant.
#
# external: Open Platform expects these infrastructure components to already be running.
#           Best for clusters that host other workloads (KubeVirt VMs, DNS, monitoring)
#           where infrastructure has its own lifecycle.
#
#           Required pre-existing components:
#             - Traefik (watching all namespaces for Ingress resources)
#             - CNPG operator (cloudnative-pg in cnpg-system namespace)
#             - Flux (GitOps controllers in flux-system namespace)
#             - cert-manager (if tls.mode=letsencrypt)
#             - MetalLB (if network.mode=loadbalancer)
#
# infrastructure:
#   mode: external
