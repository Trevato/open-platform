# Open Platform Configuration
# Only domain is required. Everything else has sensible defaults.
# Configure networking, TLS, services, and domains via the console after deploy.

domain: myplatform.example.com

# admin:
#   username: opadmin
#   email: admin@example.com

# Jitsi (video conferencing) and Zulip (team messaging) are enabled by default.
# Uncomment to disable:
# jitsi:
#   enabled: false
# zulip:
#   enabled: false
