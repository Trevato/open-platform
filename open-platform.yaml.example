# Open Platform Configuration
# Copy to open-platform.yaml and customize before deploying.

domain: myplatform.example.com

# Optional: prefix for service subdomains (for multi-tenant hosting)
# When set, services become {prefix}forgejo.{domain}, {prefix}ci.{domain}, etc.
# Leave unset or empty for standard behavior (forgejo.{domain}, ci.{domain}).
# service_prefix: myteam-

admin:
  username: opadmin    # "admin" is a reserved name in Forgejo
  email: admin@example.com

tls:
  # letsencrypt: Real certs via cert-manager (recommended for public deployments)
  # selfsigned:  Self-signed CA (for air-gapped or local development)
  # cloudflare:  Cloudflare tunnel handles TLS at edge (self-signed in-cluster)
  mode: letsencrypt
  email: admin@example.com

# Optional: Cloudflare tunnel (only used when tls.mode == cloudflare)
# cloudflare:
#   account_tag: ""
#   tunnel_id: ""
#   tunnel_secret: ""

# Instance provisioning (optional — enables child platform creation via vCluster)
# provisioner:
#   enabled: true
