# Open Platform Configuration
# Only domain is required. Everything else has sensible defaults.
# Configure networking, TLS, services, and domains via the console after deploy.

domain: myplatform.example.com

# admin:
#   username: opadmin
#   email: admin@example.com

# Jitsi (video conferencing) and Zulip (team messaging) are enabled by default.
# Uncomment to disable:
# jitsi:
#   enabled: false
# zulip:
#   enabled: false

# pgAdmin 4 (database management) — disabled by default:
# pgadmin:
#   enabled: true

# Infrastructure mode: "bundled" (default) or "external"
#
# bundled: Open Platform installs and manages Traefik, MetalLB, cert-manager,
#          CNPG, and Flux. Deploys directly on the host cluster.
#          Best for fresh clusters where OP is the only tenant.
#
# external: Open Platform deploys into its own vCluster and consumes
#           pre-existing infrastructure on the host cluster.
#           Best for production clusters that host other workloads
#           (KubeVirt VMs, DNS, monitoring, AI services) where
#           infrastructure has its own lifecycle.
#
#           Required pre-existing components on host:
#             - Traefik (watching all namespaces for Ingress resources)
#             - CNPG operator (cloudnative-pg in cnpg-system namespace)
#             - Flux (GitOps controllers in flux-system namespace)
#             - vCluster operator
#             - cert-manager (if tls.mode=letsencrypt)
#             - MetalLB (if network.mode=loadbalancer)
#
#           See docs/external-infrastructure.md for the full architecture
#           and the nixos-k8s companion project for a reference
#           infrastructure implementation.
#
# infrastructure:
#   mode: external

# Network mode: host (default) or loadbalancer (MetalLB)
# Use loadbalancer for multi-node production clusters.
# network:
#   mode: loadbalancer
#   traefikIp: 10.0.16.10
#   addressPool: 10.0.16.0/24
#   interface: eno3

# Multinode (optional — single-node works without this)
# nodes:
#   server:
#     role: infra                  # scheduling label for server node
#   agents:
#     - name: worker-1
#       address: 192.168.64.7     # IP reachable from server
#       type: colima              # colima | nixos | generic
#       role: worker              # worker | infra
#
# Enterprise HA (3 NixOS servers with embedded etcd):
# NixOS module config for each node — see nix/modules/open-platform.nix
#
# First server (nix01):
#   services.open-platform.clusterInit = true;
#   services.open-platform.nodeExternalIp = "100.84.55.62";  # Tailscale
#   services.open-platform.tlsSans = [ "100.84.55.62" "10.0.0.10" ];
#   services.open-platform.maxPods = 250;
#   services.open-platform.nodeCidrMaskSize = 20;
#   services.open-platform.network.mode = "loadbalancer";
#
# Joining servers (nix02, nix04):
#   services.open-platform.serverAddr = "https://10.0.0.10:6443";
#   services.open-platform.tokenFile = /etc/k3s-token;
#   services.open-platform.nodeExternalIp = "100.107.27.32";  # Tailscale
#   services.open-platform.tlsSans = [ "100.107.27.32" "10.0.0.11" ];
